<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <meta name="description" content={{description | safe}}/>
        <meta name="keywords" content={{keywords | safe}}/>
        <meta name="author" content={{author | safe}} />
        <link rel="icon" type="image/svg+xml" href="/book.svg"/>
        <title>{{title | safe}}</title>
        <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css"/>
        <style>
            a {text-decoration: none; color: blue;}
        </style>
    </head>
    <body>
        <div class="w3-sidebar w3-collapse w3-card" style="width:300px;" id="mySidebar">
            <button class="w3-button w3-hide-large w3-white w3-hover-white w3-right" onclick="w3_close()">Close &times;</button>
            <div class="w3-bar-block">
                <a href="/" class="w3-bar-item w3-button">&#127968; Home</a>
                {% if relatedBooks %}
                    {% for book in relatedBooks %}
                        <a href="{{book.link | safe}}" class="w3-btn w3-bar-item">{{book.title | safe}}</a>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
        <main class="w3-main" style="margin-left:300px">
            <header>
                <button class="w3-button w3-large w3-hide-large" onclick="w3_open()">&#9776;</button>
                <div class="w3-bar w3-container">
                    <h1>&#129413; Memanah Rajawali</h1>
                    <a class="w3-btn w3-round-large w3-border" href="/" title="Back Home">&#127968;</a>
                    {% if prev %}
                    <a class="w3-btn w3-round-large w3-border" href="/content/memanah-rajawali/{{prev}}" title="{{prev}}">&#9194; Previous</a>
                    {% endif %}
                    {% if next %}
                    <a class="w3-btn w3-round-large w3-border" href="/content/memanah-rajawali/{{next}}" title="{{next}}">&#9193; Next</a>
                    {% endif %}
                </div>
            </header>
            <div class="w3-container">
                {{ content | safe }}
            </div>
        </main>
    </body>
<script>
function w3_open() {
  document.getElementById("mySidebar").style.display = "block";
}

function w3_close() {
  document.getElementById("mySidebar").style.display = "none";
}
</script>
</html>
