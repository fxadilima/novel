<div class="w3-sidebar w3-collapse w3-card" style="width:300px;" id="mySidebar">
    <button class="w3-button w3-hide-large w3-white w3-hover-white w3-right" onclick="w3_close()">Close &times;</button>
    
    <div class="w3-bar">
        <a href="/" class="w3-bar-item">&#127968;</a>
        {% if prev %}
          <a class="w3-bar-item" href="/content/memanah-rajawali/{{prev}}" title="{{prev}}">&#128072;</a>
        {% endif %}
        {% if next %}
        <a class="w3-bar-item" href="/content/memanah-rajawali/{{next}}" title="{{next}}">&#128073;</a>
        {% endif %}
    </div>
    
    {% if cover %}
        <div class="w3-container">
            <div class="w3-card-4 w3-round w3-black">
                <img src={{cover.image}} alt={{cover.header}} style="width:100%"/>
                <footer class="w3-container w3-center">
                    <h2>{{cover.header | safe}}</h2>
                    <h3>{{cover.footer | safe}}</h3>
                </footer>
            </div>
        </div>
    {% endif%}

    <div class="w3-bar-block">
        {% if relatedBooks %}
            {% for book in relatedBooks %}
                <a href="{{book.link | safe}}" class="w3-btn w3-bar-item">{{book.title | safe}}</a>
            {% endfor %}
        {% endif %}
    </div>
</div>
<script>
function w3_open() {
  document.getElementById("mySidebar").style.display = "block";
}

function w3_close() {
  document.getElementById("mySidebar").style.display = "none";
}
</script>
